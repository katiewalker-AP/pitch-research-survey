# ── Survey submission ─────────────────────────────────────────────────────────
# Google Apps Script Web App URL that accepts JSON POST requests.
# Server-side only (no NEXT_PUBLIC prefix) — never exposed to the browser.
FORM_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Results dashboard ─────────────────────────────────────────────────────────
# Google Cloud API key with Google Sheets API enabled.
# The target spreadsheet must be set to "Anyone with the link can view".
GOOGLE_SHEETS_API_KEY=AIzaSy_YOUR_KEY_HERE
